# Copy to .env and fill in. Never commit .env.
#
# Production defaults can live in config/static-public-env.ts so you do not need host env UI.

# Public site URL (no trailing slash). Canonical URLs, Open Graph, sitemap, and robots.txt.
# NUXT_PUBLIC_SITE_URL=https://your-domain.com

# SQLite (optional). On Netlify/Lambda, the app uses /tmp automatically; override only if needed.
# GOD_JOBS_DATA_DIR=/tmp/god-jobs-data
# GOD_JOBS_SQLITE_PATH=/tmp/god-jobs-data/god-jobs.sqlite
#
# Netlify: prefer relying on auto `NETLIFY=true`. If you use a custom env name instead:
# SERVER_PRESET=netlify
#
# After new Drizzle migrations, update `server/utils/bundled-migration-sql.ts` for serverless.

# --- Outbound email (SMTP; e.g. Gmail with App Password) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
MAIL_FROM="Your Name <your@gmail.com>"
# Default subject if startup row has no email_subject
OUTREACH_SUBJECT=Introduction

# Optional: higher GitHub API rate limits for /api/fetch/startups (type github)
# GITHUB_TOKEN=
