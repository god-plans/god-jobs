# Copy to .env and fill in. Never commit .env.

# Public site URL (no trailing slash). Canonical URLs, Open Graph, sitemap, and robots.txt.
# NUXT_PUBLIC_SITE_URL=https://your-domain.com

# --- Outbound email (SMTP; e.g. Gmail with App Password) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
MAIL_FROM="Your Name <your@gmail.com>"
# Default subject if startup row has no email_subject
OUTREACH_SUBJECT=Introduction

# Optional: higher GitHub API rate limits for /api/fetch/startups (type github)
# GITHUB_TOKEN=
